<style is:global>
  /* ═══════════════════════════════════════════════════
     音乐播放器 — 双主题 + 清晰图标体系
     参考: Spotify / Apple Music / 网易云音乐
     ═══════════════════════════════════════════════════ */

  /* ── CSS 变量 (dark 默认) ── */
  .ap-wrapper {
    --ap-theme: #D94A4A;
    --ap-bg: #1A1618;
    --ap-border: rgba(255, 255, 255, 0.06);
    --ap-title: #FFFFFF;
    --ap-artist: #999999;
    --ap-track-name: #EEEEEE;
    --ap-muted: #666666;
    --ap-progress-track: #3A3A3A;
    --ap-hover: rgba(255, 255, 255, 0.04);
    --ap-active-bg: color-mix(in srgb, var(--ap-theme) 14%, transparent);
    --ap-shadow: 0 8px 40px rgba(0, 0, 0, 0.45);
    --ap-ctrl-icon: #888888;
    --ap-ctrl-hover: #CCCCCC;
    display: flex;
    gap: 24px;
    max-width: 920px;
    margin: 0 auto;
    align-items: flex-start;
    justify-content: center;
  }

  /* 浅色模式进度条拖拽点加边框 */
  html[data-theme="light"] .ap-progress-thumb {
    box-shadow: 0 1px 4px rgba(0,0,0,0.25);
    border: 1px solid rgba(0,0,0,0.1);
  }
  html[data-theme="light"] .ap-wrapper {
    --ap-bg: #F2EDE8;
    --ap-border: rgba(0, 0, 0, 0.08);
    --ap-title: #1A1A1A;
    --ap-artist: #777777;
    --ap-track-name: #2C2C2C;
    --ap-muted: #999999;
    --ap-progress-track: #D5D0CA;
    --ap-hover: rgba(0, 0, 0, 0.04);
    --ap-active-bg: color-mix(in srgb, var(--ap-theme) 12%, transparent);
    --ap-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    --ap-ctrl-icon: #777777;
    --ap-ctrl-hover: #333333;
  }

  /* ══════ 播放器卡片 ══════ */
  .ap-root {
    flex: 1;
    min-width: 0;
    max-width: 520px;
    background: var(--ap-bg);
    border: 1px solid var(--ap-border);
    border-radius: 24px;
    padding: 28px;
    color: var(--ap-track-name);
    backdrop-filter: blur(10px);
    box-shadow: var(--ap-shadow);
  }

  /* ── 封面 ── */
  .ap-cover {
    width: 120px; height: 120px;
    border-radius: 16px;
    overflow: hidden;
    margin: 0 auto 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }
  .ap-cover-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ap-cover-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, var(--ap-theme), color-mix(in srgb, var(--ap-theme) 40%, var(--ap-bg)));
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 48px; user-select: none;
  }

  /* ── 专辑信息 ── */
  .ap-album-title {
    margin: 0 0 4px; font-size: 22px; font-weight: 700;
    color: var(--ap-title); text-align: center; line-height: 1.3; letter-spacing: 0.02em;
  }
  .ap-album-artist {
    margin: 0 0 22px; font-size: 15px; color: var(--ap-artist);
    text-align: center; line-height: 1.4;
  }

  /* ── 曲目列表 ── */
  .ap-list { display: flex; flex-direction: column; margin-bottom: 4px; }
  .ap-track {
    display: flex; align-items: center; gap: 0;
    width: 100%; padding: 10px 8px;
    border: none; border-left: 3px solid transparent; border-radius: 8px;
    background: transparent; color: inherit; cursor: pointer;
    font-family: inherit; font-size: 1rem; text-align: left;
    transition: background 0.2s ease, border-color 0.2s ease, padding 0.2s ease;
  }
  .ap-track:hover { background: var(--ap-hover); }

  .ap-track.active {
    background: var(--ap-active-bg);
    border-left: 3px solid var(--ap-theme);
    padding-left: 5px; border-radius: 0 8px 8px 0;
    box-shadow: inset 0 0 20px color-mix(in srgb, var(--ap-theme) 6%, transparent);
  }
  .ap-track.active .ap-tnum { color: var(--ap-theme); font-weight: 600; }
  .ap-track.active .ap-tname { color: var(--ap-title); font-weight: 500; }
  .ap-track.active .ap-tdur { color: var(--ap-theme); }


  .ap-tnum {
    flex-shrink: 0; width: 32px; text-align: right;
    font-size: 14px; color: var(--ap-muted);
    font-family: "IBM Plex Mono", "Consolas", monospace;
    padding-right: 12px;
  }
  .ap-tname {
    flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    line-height: 1.5; font-size: 16px; color: var(--ap-track-name); padding-right: 30px;
