            <span class="ap-tdur">${durStr}</span>
          </button>`;
        })
        .join("");
      if (pageInfo) pageInfo.textContent = `${page + 1} / ${totalPages}`;
      if (prevPageBtn) prevPageBtn.disabled = page === 0;
      if (nextPageBtn) nextPageBtn.disabled = page >= totalPages - 1;
    }

    function highlight(idx) {
