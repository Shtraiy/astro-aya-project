---
export interface Props {
  title: string;
  artist: string;
  theme: string;
  cover: string;
  slug: string;
}

const { title, artist, theme, cover, slug } = Astro.props;
---

<div class="cd" style=`--theme: ${theme}`>
  <a href=`/music/${slug}/`>
    <div class="circle">
      <img class="avatar" src={cover} alt={title} loading="lazy" />
    </div>
  </a>
  <div class="content">
    <div class="name">{title}</div>
    <div class="description">{artist}</div>
  </div>
</div>

<style>
  .cd {
    position: relative;
    display: inline-block;
    border-radius: 30px;
    padding: 0 4px 0 0;
    margin-right: -4px;
    margin-bottom: 5px;
  }
  .circle {
    position: relative;
    width: 135px;
    height: 132px;
    display: flex;
    justify-content: center;
    align-items: center;
    background-image: url("/images/cd盒.png");
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
  }
  .avatar {
    width: 124px;
    height: 124px;
    object-fit: cover;
    border-radius: 2px;
  }
  .content {
    position: absolute;
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    background: rgba(22, 22, 32, 0.95);
    border-left: 3px solid var(--theme, #888);
    color: #e0e0e0;
    padding: 8px 14px;
    border-radius: 6px;
    white-space: nowrap;
    max-width: 90vw;
    overflow: hidden;
    text-overflow: ellipsis;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease;
    z-index: 20;
    pointer-events: none;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.35);
    text-align: center;
  }
  .content::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: var(--theme, #888);
  }
  .cd:hover .content {
    opacity: 1;
    visibility: visible;
  }
  .name {
    font-weight: bold;
    font-size: 0.83rem;
    color: #fff;
  }
  .description {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.7);
    margin-top: 2px;
  }

  /* 浅色模式 */
  html[data-theme="light"] .content {
    background: rgba(255, 255, 255, 0.95);
    color: #333;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  }
  html[data-theme="light"] .name {
    color: #1a1a1a;
  }
  html[data-theme="light"] .description {
    color: rgba(0, 0, 0, 0.6);
  }

  /* Mobile: always show info inline below the CD */
  @media (hover: none) and (pointer: coarse) {
    .content {
      position: static;
      transform: none;
      opacity: 1;
      visibility: visible;
      background: transparent;
      border-left: 2px solid var(--theme, #888);
      color: var(--theme);
      padding: 4px 0 4px 8px;
      margin-top: 6px;
      box-shadow: none;
      pointer-events: auto;
      border-radius: 0;
      z-index: auto;
    }
    .content::after {
      display: none;
    }
    .name {
      color: inherit;
      font-size: 0.78rem;
    }
    .description {
      color: inherit;
      opacity: 0.7;
      font-size: 0.67rem;
    }
    /* 浅色模式下移动端确保文字可读 */
    html[data-theme="light"] .content {
      color: #333;
    }
  }
</style>
