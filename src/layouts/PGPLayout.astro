---
import { SITE } from "@config";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import Layout from "./Layout.astro";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <Header />
  <div class="mx-auto flex w-full max-w-3xl justify-start px-2">
    <a href="/about/" class="focus-outline mb-2 mt-8 flex items-center hover:opacity-75">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
        ><path
          d="M13.293 6.293 7.586 12l5.707 5.707 1.414-1.414L10.414 12l4.293-4.293z"
        ></path>
      </svg><span>返回关于我</span>
    </a>
  </div>
  <main id="main-content">
    <section id="pgp" class="prose mb-28 max-w-3xl prose-img:border-0">
      <h1 class="text-2xl font-semibold tracking-wider sm:text-3xl">{frontmatter.title}</h1>
      <slot />
    </section>
  </main>
  <Footer />
</Layout>

