# Auto detect text files and perform LF normalization
* text=auto

# Keep source and documentation line endings stable across Windows/Linux
*.astro text eol=lf
*.css text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
